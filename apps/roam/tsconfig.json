{
  "extends": "@repo/typescript-config/react-library.json",
  "include": [
    "src",
    "src/types.d.ts",
    "tailwind.config.ts",
    "tests",
    "scripts"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": false,
    "noUncheckedIndexedAccess": false,
    "types": ["react", "react-dom"],
    "paths": {
      "~/*": ["./src/*"]
    }
  }
}
